# نمونهٔ متغیرهای محیطی CryptoSmart Hub.
# این فایل را روی سرور به نام .env کپی کنید و کلیدهای واقعی را قرار دهید.
# ⚠️ فایل .env هرگز نباید در گیت کامیت شود (در .gitignore است).

# CoinMarketCap (شاخص‌های کلان + فصل آلت‌کوین) — پلن Basic
CMC_API_KEY=

# CryptoRank (منسوخ — دیگر استفاده نمی‌شود؛ برای سازگاری باقی مانده)
CRYPTORANK_API_KEY=

# Toobit (تاپ گینرها) — اندپوینت عمومی است؛ کلیدها برای فاز بعد
TOOBIT_ACCESS_KEY=
TOOBIT_SECRET_KEY=

# Tabdeal (تتر تومانی)
TABDEAL_API_KEY=
TABDEAL_API_SECRET=

# SourceArena (طلای ۱۸ عیار)
SOURCEARENA_TOKEN=

# Dify (چت‌بات ثبت دارایی — asset_registration.yml)
DIFY_API_BASE=http://38.252.8.181/v1
DIFY_API_KEY=
# مشاور سبد (portfolio_advisor.yml) — ورک‌فلوِ سه سبد هفتگی/ماهانه/سالانه
DIFY_ADVISOR_KEY=

# مشاور سبد (ابزار تحلیل بازار برای ورک‌فلو Dify؛ راهنما: dify/README.md)
# کلید مشترک بین ورک‌فلو Dify و اندپوینت /api/advisor/context.
# ⚠️ یک رشتهٔ تصادفیِ بلند بگذارید:  python -c "import secrets; print(secrets.token_urlsafe(32))"
ADVISOR_API_KEY=

# سبدچینی با هوش مصنوعی (ALGO SMART) — راهنمای ساخت ورک‌فلو: docs/algo_allocation_workflow.md
# کلید API ورک‌فلوِ Dify که سبد پیشنهادی را می‌سازد (از صفحهٔ API ورک‌فلو در Dify بگیرید).
DIFY_ALLOCATION_BASE=http://38.252.8.181/v1
DIFY_ALLOCATION_KEY=
# نام فیلد خروجی End node ورک‌فلو که متن سبد را برمی‌گرداند (پیش‌فرض: result).
DIFY_ALLOCATION_OUTPUT=result
# توکن ربات «الگو آنالایزر» (عضو/ادمین کانال) برای خواندن تحلیل‌های کانال.
# از @BotFather بگیرید. ربات باید ادمین کانال باشد و وب‌هوک نداشته باشد.
ALGO_ANALYZER_BOT_TOKEN=
# شناسهٔ کانال سیگنال‌ها و نشانی‌های عضویت (پیش‌فرض‌ها معمولاً نیازی به تغییر ندارند).
ALGO_CHANNEL_ID=-1002341340633
ALGO_CHANNEL_URL=https://t.me/CRYPTOSMART_ORG
ALGO_SIGNUP_BOT_URL=https://t.me/cryptosmart_futures_bot

# سیگنال‌های کانال پورتفولیو (ربات portfolio_Cryptosmart_bot)
# توکن ربات از @BotFather. ربات باید «ادمین» کانال Portfolio_CryptoSmart باشد تا
# تلگرام پست‌های کانال (تحلیل ارز + تصویر چارت) را از طریق وب‌هوک برای ما بفرستد.
# هر تحلیل به مدت SIGNALS_TTL_DAYS روز در پیشنهادهای سبدچینی هوش مصنوعی لحاظ می‌شود.
SIGNALS_BOT_TOKEN=
SIGNALS_CHANNEL_ID=-1004451073096
SIGNALS_CHANNEL_URL=https://t.me/Portfolio_CryptoSmart
SIGNALS_TTL_DAYS=7
# نشانیِ عمومیِ این برنامه (برای ثبت وب‌هوک تلگرام و ساخت URL تصاویر چارت).
PUBLIC_BASE_URL=https://portfolio.cryptosmart.site
# توکن مخفیِ تأیید وب‌هوک (اختیاری). اگر خالی بماند از ADMIN_SECRET_KEY مشتق می‌شود.
SIGNALS_WEBHOOK_SECRET=
# شناسهٔ عددیِ کاربرانِ تلگرامِ مجاز به دکمهٔ «نمای کلی بازار» در چتِ خصوصیِ ربات
# (با کاما جدا؛ از @userinfobot بگیرید). خالی = بدون محدودیت (توصیه: پر شود).
TELEGRAM_ADMIN_IDS=

# تصویر روزانهٔ «نمای کلی بازار» (هر روز ۱۱:۰۰ تهران در همان کانال منتشر می‌شود).
# با همان SIGNALS_BOT_TOKEN ارسال می‌شود (ربات باید ادمین کانال باشد).
# برای ساخت تصویر، یک مرورگر Chromium لازم است. اگر در PATH نبود یا مسیرش
# غیراستاندارد بود، مسیر باینری را اینجا تعیین کنید (مثلاً /usr/bin/chromium):
# CHROMIUM_BIN=/usr/bin/chromium

# Resend (ارسال کد تأیید و بازیابی رمز)
RESEND_API_KEY=
MAIL_FROM_EMAIL=cryptosmart@cryptosmart.site
MAIL_FROM_NAME=کریپتو اسمارت

# پنل مدیریت
# ایمیل‌هایی که خودکار نقش «ادمین» می‌گیرند (با کاما جدا کنید)
ADMIN_EMAILS=cryptosmart@cryptosmart.site
# کلید رمزنگاریِ برگشت‌پذیرِ گذرواژه (برای نمایش رمز کاربر به ادمین).
# ⚠️ حتماً با یک رشتهٔ تصادفیِ بلند و یکتا جایگزین شود.
ADMIN_SECRET_KEY=

# سایر تنظیمات اختیاری
DEBUG=false
