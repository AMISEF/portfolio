# ===== CryptoSmart Hub — نمونهٔ متغیرهای محیطی =====
# این فایل را به .env کپی کنید و کلیدهای واقعی را قرار دهید.
# روی سرور، فایل .env را دستی ایجاد کنید (در گیت قرار نمی‌گیرد).

DEBUG=true

# --- CryptoRank ---
CRYPTORANK_API_KEY=your_cryptorank_key_here
# سقف کردیت پلن رایگان (پیش‌فرض‌ها مناسب‌اند)
CRYPTORANK_MONTHLY_CREDITS=10000
CRYPTORANK_DAILY_CREDITS=400
CRYPTORANK_TTL=600

# --- Toobit ---
TOOBIT_ACCESS_KEY=your_toobit_access_key
TOOBIT_SECRET_KEY=your_toobit_secret_key

# --- Tabdeal ---
TABDEAL_API_KEY=your_tabdeal_key
TABDEAL_API_SECRET=your_tabdeal_secret

# --- SourceArena (طلای ۱۸ عیار، پراکسی خارج) ---
SOURCEARENA_TOKEN=your_sourcearena_token
